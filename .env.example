# LLM Provider: deepseek | kimi
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxx
# DeepSeek: https://api.deepseek.com
# Kimi: https://api.moonshot.cn/v1
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_V3=deepseek-chat
LLM_MODEL_R1=deepseek-reasoner

# Search Provider: mock | searxng | tavily
SEARCH_PROVIDER=mock
SEARXNG_URL=http://searxng:8080
# TAVILY_API_KEY=tvly-xxx

# Database & Cache
DATABASE_URL=postgres://decisioncourt:decisioncourt@postgres:5432/decisioncourt?sslmode=disable
REDIS_URL=redis://redis:6379

# Server
PORT=8080
JWT_SECRET=decisioncourt-secret
