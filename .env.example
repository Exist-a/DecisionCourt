# DecisionCourt v0.8.3 .env 模板
#
# 用法:
#   cp .env.example .env
#   编辑 .env 填入真实 key
#   docker compose up -d
#
# 安全红线（AGENTS.md §8）：
#   - .env 永远不提交到 git
#   - 真实 LLM_API_KEY / JWT_SECRET / POSTGRES_PASSWORD 只能放 .env,由你手工填
#   - .env.example 仅做模板,key 留空或写 placeholder

# ====== LLM (P0-4 启动校验) ======
# LLM_API_KEY 必填(没 key 程序会 warning 但不 crash;有 key 才能用 LLM)
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_V3=deepseek-chat
LLM_MODEL_R1=deepseek-reasoner

# ====== Search (v0.8.3 决定:统一 Bocha,SearXNG / DuckDuckGo 已弃用) ======
# provider 选项: mock / bocha / tavily(占位)
# 推荐:生产 bocha(必填 BOCHA_API_KEY);dev 可用 mock
SEARCH_PROVIDER=bocha
# TAVILY_API_KEY=tvly-xxx
# BOCHA_API_KEY=sk-bocha-xxx  # 必填(选 bocha 时)

# ====== Database (P0-3 容器硬化) ======
# 用 32 字符以上随机字符串。生产示例:
#   openssl rand -base64 32 | tr -d '/+=' | head -c 32
POSTGRES_USER=decisioncourt
POSTGRES_PASSWORD=
POSTGRES_DB=decisioncourt
# v0.8.3 安全(P2-1):docker 网络内网用 sslmode=disable OK;
# 跨主机 / 外网 DB 必须用 sslmode=require 或 verify-full(防中间人嗅探)。
DATABASE_URL=postgres://decisioncourt:CHANGEME@postgres:5432/decisioncourt?sslmode=disable
REDIS_URL=redis://redis:6379

# ====== Server ======
PORT=8080

# ====== JWT 鉴权 (P0-2 安全) ======
# JWT_SECRET 必填,无默认值。生成:
#   openssl rand -base64 48
# 注意:换 key 后所有现有 token 失效,用户会被踢出登录。
JWT_SECRET=
JWT_EXPIRY_HOURS=168

# ====== Cookie (生产 HTTPS 必须) ======
# COOKIE_SECURE: dev (HTTP localhost) 设 false;生产 HTTPS 设 true
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
# COOKIE_DOMAIN=.yourdomain.com  # 跨子域共享;单域留空

# ====== CORS 白名单 (P1-1 安全) ======
# 逗号分隔。dev: http://localhost:3000;生产: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ====== Frontend (构建时注入) ======
# 容器内访问用 backend 主机名;宿主机访问用 localhost
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_USE_MOCK=false

# ====== v0.9 LLM Gateway (ADR 0013) ======
# per-call timeout:单次 LLM 调用最大时长。默认 90s,
# 超过会 context cancel → fallback 到 keyword-based estimation(若启用)。
AGENT_GATEWAY_LLM_TIMEOUT_SEC=90
# Response Cache:同 model + prompt + temperature 24h 内复用。
# 测试阶段默认关闭(线上再开);生产环境建议开(true)。
AGENT_GATEWAY_CACHE_ENABLED=true
AGENT_GATEWAY_CACHE_TTL_SEC=300
AGENT_GATEWAY_CACHE_MAX_ENTRIES=10000
# Circuit Breaker:连续失败后熔断 30s。
# 测试阶段默认关闭;生产环境强烈建议开(true),防止 LLM 故障拖垮服务。
AGENT_GATEWAY_BREAKER_ENABLED=true
AGENT_GATEWAY_BREAKER_FAILURE_RATIO=0.5
AGENT_GATEWAY_BREAKER_MIN_REQUESTS=10
AGENT_GATEWAY_BREAKER_OPEN_TIMEOUT_SEC=30

# ====== v0.9 用户级 Trial 限流 (ADR 0014) ======
# 每用户每天最多 StartTrial 次数。0 = 禁用(测试阶段建议 5,生产 20)。
USER_TRIAL_LIMIT=5

# ====== v0.9 Idempotency (ADR 0012 §决策 2) ======
# 客户端发 Idempotency-Key header,服务端 24h 去重。
# 留空用默认 24h。0 = 禁用(不推荐)。
IDEMPOTENCY_TTL_HOURS=24

# ====== Caddy 反代 (公网部署) ======
# Caddy 自动申请 Let's Encrypt 证书,只暴露 80/443。
# 用你的实际域名替换,否则 Caddy 启动会失败。
DOMAIN=example.com
CADDY_EMAIL=admin@example.com
