# DecisionCourt 生产环境 .env 模板 (P0-2)
#
# ⚠️ 这个文件不进 git (.gitignore 已忽略 .env*)
# ⚠️ 部署前必须用下列命令重新生成所有 SECRET / KEY
# ⚠️ 任何泄漏的 secret 立即轮换 —— 日志/Slack/GitHub 都搜一遍
#
# 用法:
#   1. cp deploy/.env.production.template .env.production
#   2. 填真值(下面所有占位符)
#   3. docker compose --env-file .env.production up -d
#
# 必填项目(全部 :? fail-fast,缺一不可):
# ============================================

# ====== 数据库(必须重新生成,dev 值是公开的) ======
POSTGRES_USER=decisioncourt
# 生成命令: openssl rand -base64 32 | tr -d '=+/' | cut -c1-32
POSTGRES_PASSWORD=<openssl rand -base64 32 输出>
POSTGRES_DB=decisioncourt
# 同步更新 DATABASE_URL 里的密码部分
DATABASE_URL=postgres://decisioncourt:<POSTGRES_PASSWORD>@postgres:5432/decisioncourt?sslmode=disable

# ====== JWT(必须重新生成,dev 值已在 git 历史) ======
# 生成命令: openssl rand -base64 64
JWT_SECRET=<openssl rand -base64 64 输出>
# Token 过期(小时)。默认 168=7天
JWT_EXPIRY_HOURS=168

# ====== LLM API Key(从 deepseek/kimi/qwen 官网申请) ======
LLM_PROVIDER=deepseek
LLM_API_KEY=<DeepSeek console 申请>
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_V3=deepseek-chat
LLM_MODEL_R1=deepseek-reasoner

# ====== 搜索引擎 API Key(默认 Bocha,也可换 Tavily) ======
SEARCH_PROVIDER=bocha
BOCHA_API_KEY=<Bocha AI console 申请>
TAVILY_API_KEY=

# ====== Cookie / CORS(生产必须改 HTTPS) ======
# 生产 HTTPS-only 必须 true(HTTPS-only cookie)
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax
# CORS 白名单用生产域名,逗号分隔多个
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ====== v0.9 LLM Gateway(生产建议全开,P0-5) ======
# per-call timeout,默认 90s 适合 deepseek
AGENT_GATEWAY_LLM_TIMEOUT_SEC=90
# Response Cache:同 prompt 24h 内复用,命中率预期 30-40%(相同议题反复开庭)
AGENT_GATEWAY_CACHE_ENABLED=true
AGENT_GATEWAY_CACHE_TTL_SEC=300
AGENT_GATEWAY_CACHE_MAX_ENTRIES=10000
# Circuit Breaker:LLM 连续失败后熔断,fallback 返回降级响应
AGENT_GATEWAY_BREAKER_ENABLED=true
AGENT_GATEWAY_BREAKER_FAILURE_RATIO=0.5
AGENT_GATEWAY_BREAKER_MIN_REQUESTS=10
AGENT_GATEWAY_BREAKER_OPEN_TIMEOUT_SEC=30

# ====== v0.9 用户级 Trial 限流(ADR 0014) ======
# 生产每用户每天 5-20 次。初期保守 5,运营稳定后改 20。
USER_TRIAL_LIMIT=5

# ====== v0.9 Idempotency(ADR 0012 §决策 2) ======
# 24h TTL。0=禁用(不推荐)。
IDEMPOTENCY_TTL_HOURS=24

# ====== Caddy 反代(自动 HTTPS) ======
DOMAIN=yourdomain.com
CADDY_EMAIL=admin@yourdomain.com

# ====== Frontend 构建时注入 ======
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_WS_URL=wss://yourdomain.com
NEXT_PUBLIC_USE_MOCK=false

# ====== 后端服务端口(默认 8080) ======
PORT=8080